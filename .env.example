# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and auto-loaded by Vitest (see vitest.config.ts).

# Azure OpenAI
AZURE_OPENAI_API_DEPLOYMENT="your-azure-deployment-name"
AZURE_OPENAI_API_KEY="your-azure-api-key"
AZURE_OPENAI_API_VERSION="your-azure-api-version"
AZURE_OPENAI_ENDPOINT="your-azure-endpoint-url"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"

# GOOGLE_API_KEY
GOOGLE_API_KEY="your-google-api-key"

# Monocle blob exporter
MONOCLE_BLOB_CONNECTION_STRING="your-blob-connection-string"
MONOCLE_BLOB_CONTAINER_NAME="your-blob-container-name"

# OpenSearch
OPENSEARCH_ENDPOINT_URL_BOTO="your-opensearch-endpoint-boto"
OPENSEARCH_ENDPOINT_URL="your-opensearch-endpoint"
OPENSEARCH_ENDPOINT="your-open-search-endpoint"
OPENSEARCH_DOMAIN="your-open-search-domain"
OPENSEARCH_USERNAME="your-open-search-username"
OPENSEARCH_PASSWORD="your-open-search-password"

# AWS
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_ACCESS_KEY_ID_EXPORTER="your-aws-access-key-id-exporter"
AWS_SECRET_ACCESS_KEY_EXPORTER="your-aws-secret-access-key-exporter"

# Mistral
MISTRAL_API_KEY="your-mistral-api-key"
